# bili2text-new 配置文件
# 复制此文件为 config.env 并填入你的配置

# 视频下载目录
VIDEO_DIR=downloads/video
# 音频输出目录
AUDIO_DIR=downloads/audio
# 文案输出目录
OUTPUT_DIR=outputs
# 临时文件目录
TEMP_DIR=downloads/temp

# Whisper 模型缓存目录（模型会下载到这里）
MODEL_DIR=models
# Whisper 模型大小: tiny, tiny.en, base, base.en, small, small.en, medium, medium.en, large-v1, large-v2, large-v3, large, distil-large-v2, distil-medium.en, distil-small.en
WHISPER_MODEL=medium
# Whisper 设备: cpu, cuda, auto
WHISPER_DEVICE=auto
# Whisper 计算类型: float16, int8, auto (CPU 推荐 int8, GPU 推荐 float16)
WHISPER_COMPUTE_TYPE=auto

# 音频分割长度（秒）
SLICE_LENGTH=45

# B站 Cookie（可选，用于下载更高清的视频，从浏览器获取）
# BILIBILI_COOKIE=your_cookie_here

# DeepSeek API Key（用于语言检测和翻译，处理本地视频时需要）
DEEPSEEK_API_KEY=your_key_here
